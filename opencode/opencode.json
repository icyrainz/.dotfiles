{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "akio-fractal": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "akio-fractal",
      "options": {
        "baseURL": "http://akio-fractal:8080/v1"
      },
      "models": {
        "Qwen3.5-27B": {
          "name": "Qwen3.5-27B",
          "tool_call": true
        }
      }
    }
  },
  "plugin": [
    // "oh-my-opencode@latest"
  ],
  "agent": {
    "explore": {
      "mode": "subagent",
      "description": "Explorer agent for analyzing code and writing documentation"
    },
    "general": {
      "mode": "subagent",
      "description": "General purpose subagent for various tasks"
    }
  },
  "keybinds": {
    "session_parent": "<leader>ctrl+u",
    "session_child_cycle": "<leader>ctrl+n",
    "session_child_cycle_reverse": "<leader>ctrl+p",
    "messages_half_page_up": "alt+u",
    "messages_half_page_down": "alt+d"
  },
  "mcp": {
    "deepwiki": {
      "type": "remote",
      "enabled": true,
      "url": "https://mcp.deepwiki.com/mcp"
    },
    "lightpanda": {
      "type": "local",
      "enabled": true,
      "command": [
        "/Users/tuephan/.local/bin/lightpanda",
        "mcp"
      ]
    },
    "commando": {
      "type": "remote",
      "enabled": true,
      "url": "http://commando.lan/mcp",
      "headers": {
        "Authorization": "Bearer {env:COMMANDO_API_KEY}"
      }
    },
    "windmill-mcp": {
      "type": "remote",
      "enabled": true,
      "url": "http://windmill.lan/api/mcp/w/akio-workspace/mcp?token={env:WINDMILL_MCP_TOKEN}"
    }
  }
}
