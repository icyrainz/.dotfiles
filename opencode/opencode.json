{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "akio-fractal": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "akio-fractal",
      "options": {
        "baseURL": "http://akio-fractal:8080/v1"
      },
      "models": {
        "Qwen3.5-27B": {
          "name": "Qwen3.5-27B",
          "tool_call": true
        }
      }
    }
  },
  "plugin": [
    // "oh-my-opencode@latest"
  ],
  "agent": {
    "explore": {
      "disable": true
    },
    "general": {
      "disable": true
    }
  },
  "keybinds": {
    "session_parent": "<leader>ctrl+u",
    "session_child_cycle": "<leader>ctrl+n",
    "session_child_cycle_reverse": "<leader>ctrl+p",
    "messages_half_page_up": "alt+u",
    "messages_half_page_down": "alt+d"
  },
  "mcp": {
    "n8n-mcp": {
      "type": "local",
      "enabled": false,
      "command": [
        "npx",
        "-y",
        "supergateway",
        "--streamableHttp",
        "http://n8n.lan/mcp-server/http",
        "--header",
        "authorization:Bearer {env:N8N_MCP_TOKEN}"
      ]
    },
    "windmill-mcp": {
      "type": "remote",
      "enabled": true,
      "url": "http://windmill.lan/api/mcp/w/akio-workspace/mcp?token={env:WINDMILL_MCP_TOKEN}"
    }
  }
}
